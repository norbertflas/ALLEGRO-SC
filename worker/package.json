{
  "name": "allegro-sc-worker",
  "version": "0.1.0",
  "private": true,
  "description": "Cloudflare Worker API + D1 backend for ALLEGRO-SC",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "migrate:local": "wrangler d1 migrations apply allegro-sc --local",
    "migrate:remote": "wrangler d1 migrations apply allegro-sc --remote",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250101.0",
    "typescript": "^5.7.0",
    "wrangler": "^3.99.0"
  }
}
