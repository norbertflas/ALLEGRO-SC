# Skopiuj ten plik do ".env" i uzupełnij wartości.
# Plik .env jest ignorowany przez git — token nie trafi do repo.

# Adres Twojego Workera (backend). To samo, co w dashboardzie.
WORKER_URL=https://allegro-sc.norbertflas99.workers.dev

# Ten sam token co w Workerze / dashboardzie. NIE commituj tego pliku.
INGEST_TOKEN=wstaw_tutaj_swoj_token

# Ile stron na cel (im więcej, tym dłużej). 3 to rozsądny start.
MAX_PAGES=3

# 0 = widoczne okno przeglądarki (zalecane lokalnie — widzisz co się dzieje
# i możesz ręcznie rozwiązać ewentualną captchę). 1 = tryb niewidoczny.
HEADLESS=0
